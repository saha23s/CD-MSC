{
  "seed": 42,
  "dataset_root": "./Development_data/raw_audio",
  "train_ids_path": "./Development_data/metadata/Training_ids.txt",
  "val_ids_path": "./Development_data/metadata/Validation_ids.txt",
  "test_ids_path": "./Development_data/metadata/Test_ids.txt",
  "feature_root": "./Development_data/feature",
  "output_root": "./data/Development_data/outputs",
  "sample_rate": 8000,
  "batch_size": 64,
  "eval_batch_size": 8,
  "num_workers": 4,
  "train_crop_seconds": 2.0,
  "normalize_waveform": true,
  "normalize_features": true,
  "epochs": 100,
  "early_stopping_min_epoch": 10,
  "early_stopping_patience": 5,
  "learning_rate": 0.001,
  "weight_decay": 0.0001,
  "dropout": 0.2,
  "device": "auto",
  "experiment_tag": "balanced_dann_lam0p5",
  "domain_balanced_sampling": true,
  "use_mixstyle": false,
  "mixstyle_alpha": 0.1,
  "mixstyle_p": 0.5,
  "ttbn": false,
  "domain_adversarial": true,
  "grl_lambda_max": 0.5,
  "augmentation": {
    "time_masking": {
      "enabled": false,
      "num_masks": 2,
      "max_mask_fraction": 0.15,
      "p": 1.0
    },
    "freq_masking": {
      "enabled": false,
      "num_masks": 2,
      "max_mask_bins": 8,
      "p": 1.0
    },
    "gaussian_noise": {
      "enabled": false,
      "std": 0.05,
      "p": 0.5
    },
    "freq_shift": {
      "enabled": false,
      "max_shift_bins": 4,
      "p": 0.5
    },
    "mixup": {
      "enabled": false,
      "alpha": 0.4
    },
    "hpss": {
      "enabled": false,
      "kernel_harm": 17,
      "kernel_perc": 9,
      "alpha_min": 0.0,
      "power": 2.0,
      "p": 0.5
    }
  }
}