{
  "experiment_tag": "ast_balanced_fbsmix",
  "seed": 42,
  "model_type": "ast",
  "ast_embed_dim": 192,
  "ast_depth": 4,
  "ast_num_heads": 4,
  "ast_mlp_ratio": 4,
  "ast_patch_time": 8,
  "ast_patch_freq": 8,
  "ast_dropout": 0.1,
  "domain_balanced_sampling": true,
  "domain_adversarial": false,
  "freq_band_mixstyle": true,
  "fbmix_species_lo": 9,
  "fbmix_species_hi": 36,
  "fbmix_alpha": 0.1,
  "fbmix_p": 0.5,
  "dataset_root": "./Development_data/raw_audio",
  "train_ids_path": "./Development_data/metadata/Training_ids.txt",
  "val_ids_path": "./Development_data/metadata/Validation_ids.txt",
  "test_ids_path": "./Development_data/metadata/Test_ids.txt",
  "feature_root": "./Development_data/feature",
  "output_root": "./data/Development_data/outputs",
  "sample_rate": 8000,
  "batch_size": 64,
  "eval_batch_size": 8,
  "num_workers": 4,
  "train_crop_seconds": 2.0,
  "normalize_waveform": true,
  "normalize_features": true,
  "epochs": 100,
  "early_stopping_min_epoch": 10,
  "early_stopping_patience": 5,
  "learning_rate": 0.0005,
  "weight_decay": 0.0001,
  "dropout": 0.1,
  "device": "auto",
  "augmentation": {
    "time_masking":   {"enabled": false},
    "freq_masking":   {"enabled": false},
    "gaussian_noise": {"enabled": false},
    "freq_shift":     {"enabled": false},
    "mixup":          {"enabled": false},
    "hpss":           {"enabled": false}
  },
  "max_eval_frames": 1024
}
