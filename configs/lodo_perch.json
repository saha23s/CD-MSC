{
  "experiment_tag": "perch_lodo",
  "model_type": "perch",
  "seed": 42,
  "perch_model_url": "https://tfhub.dev/google/bird-vocalization-classifier/4",
  "dataset_root": "./Development_data/raw_audio",
  "train_ids_path": "./Development_data/metadata/Training_ids.txt",
  "val_ids_path": "./Development_data/metadata/Validation_ids.txt",
  "test_ids_path": "./Development_data/metadata/Test_ids.txt",
  "feature_root": "./Development_data/perch_feature",
  "output_root": "./data/Development_data/outputs",
  "sample_rate": 8000,
  "normalize_waveform": true,
  "normalize_features": true,
  "batch_size": 128,
  "eval_batch_size": 64,
  "num_workers": 4,
  "train_crop_seconds": null,
  "epochs": 100,
  "early_stopping_min_epoch": 10,
  "early_stopping_patience": 10,
  "learning_rate": 0.001,
  "weight_decay": 0.0001,
  "dropout": 0.1,
  "perch_embed_dim": 128,
  "device": "auto",
  "domain_balanced_sampling": false,
  "use_mixstyle": false,
  "domain_adversarial": false,
  "grl_lambda_max": 1.0,
  "augmentation": {
    "time_masking":   {"enabled": false, "num_masks": 2, "max_mask_fraction": 0.15, "p": 1.0},
    "freq_masking":   {"enabled": false, "num_masks": 2, "max_mask_bins": 8,        "p": 1.0},
    "gaussian_noise": {"enabled": false, "std": 0.05,   "p": 0.5},
    "freq_shift":     {"enabled": false, "max_shift_bins": 4,                       "p": 0.5},
    "mixup":          {"enabled": false, "alpha": 0.4},
    "hpss":           {"enabled": false, "kernel_harm": 17, "kernel_perc": 9, "alpha_min": 0.0, "power": 2.0, "p": 0.5}
  }
}
